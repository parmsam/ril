---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'RIL',
  description = 'Resources I Love — a curated feed of links, resources, and learnings.',
} = Astro.props;

const pageTitle = title === 'RIL' ? 'RIL' : `${title} · RIL`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/ril/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="RIL Feed" href="/ril/feed.xml" />
    <link href="/ril/pagefind/pagefind-ui.css" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>
    <!-- prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('ril-theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="bg-stone-50 dark:bg-stone-950 text-stone-900 dark:text-stone-100 min-h-screen font-sans antialiased transition-colors">
    <header class="border-b border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 sticky top-0 z-10">
      <div class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
        <a href="/ril" class="font-semibold text-base tracking-tight hover:text-amber-600 dark:hover:text-amber-400 transition-colors">
          RIL <span class="text-stone-400 dark:text-stone-500 font-normal text-sm">resources i love</span>
        </a>
        <div class="flex items-center gap-5">
          <nav class="flex gap-5 text-sm text-stone-500 dark:text-stone-400">
            <a href="/ril/resources" class="hover:text-stone-900 dark:hover:text-stone-100 transition-colors">resources</a>
            <a href="/ril/links" class="hover:text-stone-900 dark:hover:text-stone-100 transition-colors">links</a>
            <a href="/ril/til" class="hover:text-stone-900 dark:hover:text-stone-100 transition-colors">til</a>
          </nav>
          <a
            href="https://github.com/parmsam/ril"
            aria-label="GitHub repository"
            class="text-stone-400 dark:text-stone-500 hover:text-stone-700 dark:hover:text-stone-300 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-4 h-4">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </a>
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="text-stone-400 dark:text-stone-500 hover:text-stone-700 dark:hover:text-stone-300 transition-colors"
          >
            <!-- sun: shown in dark mode -->
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 hidden">
              <path d="M10 2a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 2zM10 15a.75.75 0 01.75.75v1.5a.75.75 0 01-1.5 0v-1.5A.75.75 0 0110 15zM10 7a3 3 0 100 6 3 3 0 000-6zM15.657 5.404a.75.75 0 10-1.06-1.06l-1.061 1.06a.75.75 0 001.06 1.06l1.06-1.06zM6.464 14.596a.75.75 0 10-1.06-1.06l-1.06 1.06a.75.75 0 001.06 1.06l1.06-1.06zM18 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 0118 10zM5 10a.75.75 0 01-.75.75h-1.5a.75.75 0 010-1.5h1.5A.75.75 0 015 10zM14.596 15.657a.75.75 0 001.06-1.06l-1.06-1.061a.75.75 0 10-1.06 1.06l1.06 1.06zM5.404 6.464a.75.75 0 001.06-1.06L5.404 4.343a.75.75 0 10-1.06 1.06l1.06 1.061z"/>
            </svg>
            <!-- moon: shown in light mode -->
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
              <path fill-rule="evenodd" d="M7.455 2.004a.75.75 0 01.26.77 7 7 0 009.958 7.967.75.75 0 011.067.853A8.5 8.5 0 116.647 1.921a.75.75 0 01.808.083z" clip-rule="evenodd"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="border-b border-stone-100 dark:border-stone-800 bg-stone-50 dark:bg-stone-950">
      <div class="max-w-3xl mx-auto px-4 py-1.5 flex items-center gap-1.5 text-xs text-stone-400 dark:text-stone-500">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 text-amber-400 dark:text-amber-500 flex-shrink-0">
          <path d="M7.657 6.247c.11-.33.576-.33.686 0l.645 1.937a2.89 2.89 0 0 0 1.829 1.828l1.936.645c.33.11.33.576 0 .686l-1.937.645a2.89 2.89 0 0 0-1.828 1.829l-.645 1.936a.361.361 0 0 1-.686 0l-.645-1.937a2.89 2.89 0 0 0-1.828-1.828l-1.937-.645a.361.361 0 0 1 0-.686l1.937-.645a2.89 2.89 0 0 0 1.828-1.828l.645-1.937ZM3.794 1.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387A1.734 1.734 0 0 0 4.593 5.69l-.387 1.162a.217.217 0 0 1-.412 0L3.407 5.69A1.734 1.734 0 0 0 2.31 4.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387A1.734 1.734 0 0 0 3.407 2.31l.387-1.162ZM10.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732L9.1 2.137a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732L10.863.1Z" />
        </svg>
        <span>Descriptions, notes, and TILs marked with this icon are AI-generated. Pencil icon means my own words.</span>
      </div>
    </div>

    <main class="max-w-3xl mx-auto px-4 py-10" data-pagefind-body>
      <slot />
    </main>

    <footer class="border-t border-stone-200 dark:border-stone-800 mt-16">
      <div class="max-w-3xl mx-auto px-4 py-6 flex items-center justify-between text-xs text-stone-400 dark:text-stone-500">
        <span>sam's view of the internet</span>
        <div class="flex gap-4">
          <a href="/ril/feed.xml" class="hover:text-stone-600 dark:hover:text-stone-300 transition-colors">rss</a>
          <a href="https://github.com/parmsam/ril" class="hover:text-stone-600 dark:hover:text-stone-300 transition-colors">source</a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        var toggle = document.getElementById('theme-toggle');
        var sun = document.getElementById('icon-sun');
        var moon = document.getElementById('icon-moon');

        function updateIcons() {
          var isDark = document.documentElement.classList.contains('dark');
          sun.classList.toggle('hidden', !isDark);
          moon.classList.toggle('hidden', isDark);
        }

        updateIcons();

        toggle.addEventListener('click', function () {
          var isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('ril-theme', isDark ? 'dark' : 'light');
          updateIcons();
        });
      })();
    </script>
  </body>
</html>
