---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';
import LinkCard from '../../components/LinkCard.astro';
import TilCard from '../../components/TilCard.astro';

export async function getStaticPaths() {
  const resources = await getCollection('resources');
  const links = await getCollection('links');
  const tils = await getCollection('til');

  const allTags = new Set([
    ...resources.flatMap(r => r.data.tags),
    ...links.flatMap(l => l.data.tags),
    ...tils.flatMap(t => t.data.tags),
  ]);

  return Array.from(allTags).map(tag => ({
    params: { tag },
    props: {
      resources: resources.filter(r => r.data.tags.includes(tag)),
      links: links.filter(l => l.data.tags.includes(tag)).sort((a, b) => b.data.added.getTime() - a.data.added.getTime()),
      tils: tils.filter(t => t.data.tags.includes(tag)).sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
    },
  }));
}

const { tag } = Astro.params;
const { resources, links, tils } = Astro.props;
const total = resources.length + links.length + tils.length;
---

<Base title={`#${tag}`}>
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-1">#{tag}</h1>
    <p class="text-stone-400 text-sm">{total} {total === 1 ? 'item' : 'items'}</p>
  </div>

  {resources.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Resources</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {resources.map(r => <ResourceCard resource={r} />)}
      </div>
    </section>
  )}

  {links.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Links</h2>
      <div>
        {links.map(l => <LinkCard link={l} />)}
      </div>
    </section>
  )}

  {tils.length > 0 && (
    <section class="mb-10">
      <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">TIL</h2>
      <div>
        {tils.map(t => <TilCard entry={t} />)}
      </div>
    </section>
  )}
</Base>
