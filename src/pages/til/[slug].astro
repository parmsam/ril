---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TagPill from '../../components/TagPill.astro';
import AiIcon from '../../components/AiIcon.astro';
import PersonalIcon from '../../components/PersonalIcon.astro';

export async function getStaticPaths() {
  const entries = await getCollection('til');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, date, tags, source_url, source_title, ai_note } = entry.data;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Base title={title}>
  <article class="max-w-2xl">
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-600">TIL</span>
        <time class="text-sm text-stone-400">{dateStr}</time>
      </div>
      <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-3 leading-snug">{title}</h1>
      {source_url && (
        <p class="text-sm text-stone-400">
          via <a href={source_url} class="text-amber-600 hover:underline underline-offset-2 transition-colors" target="_blank" rel="noopener noreferrer">{source_title ?? source_url}</a>
        </p>
      )}
    </header>

    <div class="flex items-center gap-2 mb-6">
      <button id="play-pause-btn" title="Play" class="flex items-center justify-center w-7 h-7 rounded-full text-stone-400 dark:text-stone-500 hover:text-amber-600 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-950 transition-colors">
        <svg id="play-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
        <svg id="pause-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 hidden">
          <rect x="6" y="4" width="4" height="16"></rect>
          <rect x="14" y="4" width="4" height="16"></rect>
        </svg>
      </button>
      <button id="stop-btn" title="Stop" disabled class="flex items-center justify-center w-7 h-7 rounded-full text-stone-300 dark:text-stone-700 transition-colors" aria-disabled="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        </svg>
      </button>
      <span id="read-aloud-label" class="text-xs text-stone-400 dark:text-stone-500">Read aloud</span>
    </div>

    <div id="til-body" class="prose prose-stone dark:prose-invert prose-sm max-w-none mb-8 prose-a:text-amber-600 dark:prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline">
      <p class="not-prose flex items-center gap-1 text-xs text-stone-400 dark:text-stone-500 mb-4">
        {ai_note === false ? <PersonalIcon /> : <AiIcon />}
        {ai_note === false ? 'Written in my own words.' : 'AI-generated writing.'}
      </p>
      <Content />
    </div>

    <footer class="flex flex-wrap gap-1.5 pt-6 border-t border-stone-100 dark:border-stone-800">
      {tags.map(tag => <TagPill tag={tag} href={`/ril/tags/${tag}`} />)}
    </footer>
  </article>
</Base>

<script is:inline>
  const playPauseBtn = document.getElementById('play-pause-btn');
  const stopBtn = document.getElementById('stop-btn');
  const playIcon = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');
  const label = document.getElementById('read-aloud-label');
  const body = document.getElementById('til-body');
  const titleEl = document.querySelector('h1');

  const text = (titleEl?.innerText ?? '') + '. ' + (body?.innerText ?? '');
  let state = 'idle'; // 'idle' | 'speaking' | 'paused'

  function setIdle() {
    state = 'idle';
    playIcon?.classList.remove('hidden');
    pauseIcon?.classList.add('hidden');
    if (playPauseBtn) playPauseBtn.title = 'Play';
    if (stopBtn) { stopBtn.disabled = true; stopBtn.classList.replace('text-stone-400', 'text-stone-300'); stopBtn.classList.replace('dark:text-stone-500', 'dark:text-stone-700'); stopBtn.classList.remove('hover:text-amber-600', 'dark:hover:text-amber-400', 'hover:bg-amber-50', 'dark:hover:bg-amber-950'); }
    if (label) label.textContent = 'Read aloud';
  }

  function setSpeaking() {
    state = 'speaking';
    playIcon?.classList.add('hidden');
    pauseIcon?.classList.remove('hidden');
    if (playPauseBtn) playPauseBtn.title = 'Pause';
    if (stopBtn) { stopBtn.disabled = false; stopBtn.classList.replace('text-stone-300', 'text-stone-400'); stopBtn.classList.replace('dark:text-stone-700', 'dark:text-stone-500'); stopBtn.classList.add('hover:text-amber-600', 'dark:hover:text-amber-400', 'hover:bg-amber-50', 'dark:hover:bg-amber-950'); }
    if (label) label.textContent = 'Playing…';
  }

  function setPaused() {
    state = 'paused';
    playIcon?.classList.remove('hidden');
    pauseIcon?.classList.add('hidden');
    if (playPauseBtn) playPauseBtn.title = 'Resume';
    if (label) label.textContent = 'Paused';
  }

  function pickVoice() {
    const voices = window.speechSynthesis.getVoices();
    const en = voices.filter(v => v.lang.startsWith('en'));
    return (
      en.find(v => v.name.includes('Google')) ??
      en.find(v => v.name.includes('Enhanced')) ??
      en.find(v => v.lang === 'en-US') ??
      null
    );
  }

  playPauseBtn?.addEventListener('click', () => {
    if (state === 'idle') {
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.voice = pickVoice();
      utterance.onend = setIdle;
      utterance.onerror = setIdle;
      window.speechSynthesis.speak(utterance);
      setSpeaking();
    } else if (state === 'speaking') {
      window.speechSynthesis.pause();
      setPaused();
    } else if (state === 'paused') {
      window.speechSynthesis.resume();
      setSpeaking();
    }
  });

  stopBtn?.addEventListener('click', () => {
    window.speechSynthesis.cancel();
    setIdle();
  });
</script>
