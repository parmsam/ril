---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TagPill from '../../components/TagPill.astro';
import AiIcon from '../../components/AiIcon.astro';
import PersonalIcon from '../../components/PersonalIcon.astro';

export async function getStaticPaths() {
  const entries = await getCollection('til');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, date, tags, source_url, source_title, ai_note } = entry.data;
const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---

<Base title={title}>
  <article class="max-w-2xl">
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-block px-1.5 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-600">TIL</span>
        <time class="text-sm text-stone-400">{dateStr}</time>
      </div>
      <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-3 leading-snug">{title}</h1>
      {source_url && (
        <p class="text-sm text-stone-400">
          via <a href={source_url} class="text-amber-600 hover:underline underline-offset-2 transition-colors" target="_blank" rel="noopener noreferrer">{source_title ?? source_url}</a>
        </p>
      )}
    </header>

    <button
      id="read-aloud-btn"
      title="Read aloud"
      class="flex items-center gap-1.5 text-xs text-stone-400 dark:text-stone-500 hover:text-amber-600 dark:hover:text-amber-400 transition-colors mb-6"
    >
      <svg id="speak-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
      </svg>
      <svg id="stop-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 hidden">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
        <line x1="23" y1="9" x2="17" y2="15"></line>
        <line x1="17" y1="9" x2="23" y2="15"></line>
      </svg>
      <span id="read-aloud-label">Read aloud</span>
    </button>

    <div id="til-body" class="prose prose-stone dark:prose-invert prose-sm max-w-none mb-8 prose-a:text-amber-600 dark:prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline">
      <p class="not-prose flex items-center gap-1 text-xs text-stone-400 dark:text-stone-500 mb-4">
        {ai_note === false ? <PersonalIcon /> : <AiIcon />}
        {ai_note === false ? 'Written in my own words.' : 'AI-generated writing.'}
      </p>
      <Content />
    </div>

    <footer class="flex flex-wrap gap-1.5 pt-6 border-t border-stone-100 dark:border-stone-800">
      {tags.map(tag => <TagPill tag={tag} href={`/ril/tags/${tag}`} />)}
    </footer>
  </article>
</Base>

<script is:inline>
  const btn = document.getElementById('read-aloud-btn');
  const speakIcon = document.getElementById('speak-icon');
  const stopIcon = document.getElementById('stop-icon');
  const label = document.getElementById('read-aloud-label');
  const body = document.getElementById('til-body');
  const titleEl = document.querySelector('h1');

  const text = (titleEl?.innerText ?? '') + '. ' + (body?.innerText ?? '');

  function setIdle() {
    speakIcon?.classList.remove('hidden');
    stopIcon?.classList.add('hidden');
    if (label) label.textContent = 'Read aloud';
  }

  function setSpeaking() {
    speakIcon?.classList.add('hidden');
    stopIcon?.classList.remove('hidden');
    if (label) label.textContent = 'Stop';
  }

  btn?.addEventListener('click', () => {
    if (window.speechSynthesis.speaking) {
      window.speechSynthesis.cancel();
      setIdle();
    } else {
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.onend = setIdle;
      utterance.onerror = setIdle;
      window.speechSynthesis.speak(utterance);
      setSpeaking();
    }
  });
</script>
