---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import TilCard from '../../components/TilCard.astro';

const entries = await getCollection('til');
entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Base title="TIL">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-1">Today I Learned</h1>
    <p class="text-stone-400 text-sm">Short atomic notes on things worth knowing. No essays — just the thing.</p>
  </div>

  <div>
    {entries.map(e => <TilCard entry={e} />)}
  </div>
</Base>
