---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ResourceCard from '../../components/ResourceCard.astro';

const all = await getCollection('resources');
const active = all.filter(r => r.data.status === 'active').sort((a, b) => b.data.added.getTime() - a.data.added.getTime());
const archived = all.filter(r => r.data.status === 'archived').sort((a, b) => b.data.added.getTime() - a.data.added.getTime());
---

<Base title="Resources">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-stone-900 dark:text-stone-100 mb-1">Resources</h1>
    <p class="text-stone-400 text-sm">Ongoing sources I return to — blogs, podcasts, channels, newsletters.</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 mb-12">
    {active.map(r => <ResourceCard resource={r} />)}
  </div>

  {archived.length > 0 && (
    <>
      <h2 class="text-xs font-semibold text-stone-400 uppercase tracking-widest mb-4">Archived</h2>
      <div class="grid gap-4 sm:grid-cols-2">
        {archived.map(r => <ResourceCard resource={r} />)}
      </div>
    </>
  )}
</Base>
