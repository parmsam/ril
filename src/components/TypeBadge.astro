---
interface Props {
  type: string;
}
const { type } = Astro.props;

const colors: Record<string, string> = {
  article:    'bg-blue-50 text-blue-600',
  video:      'bg-red-50 text-red-600',
  post:       'bg-green-50 text-green-600',
  paper:      'bg-purple-50 text-purple-600',
  thread:     'bg-orange-50 text-orange-600',
  tool:       'bg-cyan-50 text-cyan-600',
  blog:       'bg-green-50 text-green-600',
  podcast:    'bg-violet-50 text-violet-600',
  channel:    'bg-red-50 text-red-600',
  newsletter: 'bg-blue-50 text-blue-600',
  site:       'bg-stone-100 text-stone-500',
};

const color = colors[type] ?? 'bg-stone-100 text-stone-500';
---

<span class={`inline-block px-1.5 py-0.5 rounded text-xs font-medium ${color}`}>
  {type}
</span>
