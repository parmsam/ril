---
import type { CollectionEntry } from 'astro:content';
import TagPill from './TagPill.astro';
import TypeBadge from './TypeBadge.astro';
import AiIcon from './AiIcon.astro';
import PersonalIcon from './PersonalIcon.astro';

interface Props {
  resource: CollectionEntry<'resources'>;
}
const { resource } = Astro.props;
const { title, url, description, type, tags, status, note, ai_note } = resource.data;
---

<article id={resource.id} class="group p-4 rounded-lg border border-stone-200 dark:border-stone-800 bg-white dark:bg-stone-900 hover:border-amber-300 dark:hover:border-amber-700 hover:shadow-sm transition-all scroll-mt-16">
  <div class="flex items-center justify-between gap-2 mb-2">
    <div class="flex items-center gap-2">
      <TypeBadge type={type} />
      {status === 'archived' && (
        <span class="text-xs text-stone-400 dark:text-stone-500 italic">archived</span>
      )}
    </div>
    <button
      data-copy-href={`#${resource.id}`}
      aria-label="Copy link to this entry"
      class="flex-shrink-0 opacity-0 group-hover:opacity-100 focus:opacity-100 p-0.5 rounded text-stone-400 hover:text-stone-600 dark:text-stone-500 dark:hover:text-stone-300 transition-opacity"
    >
      <svg class="copy-link-icon w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path d="M12.232 4.232a2.5 2.5 0 013.536 3.536l-1.225 1.224a.75.75 0 001.061 1.06l1.224-1.224a4 4 0 00-5.656-5.656l-3 3a4 4 0 00.225 5.865.75.75 0 00.977-1.138 2.5 2.5 0 01-.142-3.667l3-3z"/>
        <path d="M11.603 7.963a.75.75 0 00-.977 1.138 2.5 2.5 0 01.142 3.667l-3 3a2.5 2.5 0 01-3.536-3.536l1.225-1.224a.75.75 0 00-1.061-1.06l-1.224 1.224a4 4 0 005.656 5.656l3-3a4 4 0 00-.225-5.865z"/>
      </svg>
      <svg class="copy-check-icon hidden w-3.5 h-3.5 text-green-500" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
      </svg>
    </button>
  </div>
  <a href={url} target="_blank" rel="noopener noreferrer">
    <h2 class="font-semibold text-stone-900 dark:text-stone-100 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors mb-1 leading-snug">{title}</h2>
  </a>
  <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed mb-3">
    <AiIcon title="AI-generated description" />{description}
  </p>
  {note && (
    <p class="text-sm text-stone-400 dark:text-stone-500 italic border-l-2 border-amber-200 dark:border-amber-800 pl-3 mb-3">
      {ai_note === false ? <PersonalIcon /> : <AiIcon title="AI-generated note" />}{note}
    </p>
  )}
  <div class="flex flex-wrap gap-1">
    {tags.map(tag => <TagPill tag={tag} href={`/ril/tags/${tag}`} />)}
  </div>
</article>
