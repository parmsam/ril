---
interface Props {
  tag: string;
  href?: string;
}
const { tag, href } = Astro.props;
---

{href ? (
  <a href={href} class="inline-block px-2 py-0.5 rounded-full text-xs bg-stone-100 text-stone-500 hover:bg-amber-100 hover:text-amber-700 transition-colors">
    #{tag}
  </a>
) : (
  <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-stone-100 text-stone-500">
    #{tag}
  </span>
)}
