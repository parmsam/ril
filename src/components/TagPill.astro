---
interface Props {
  tag: string;
  href?: string;
}
const { tag, href } = Astro.props;
---

{href ? (
  <a href={href} class="inline-block px-2 py-0.5 rounded-full text-xs bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400 hover:bg-amber-100 dark:hover:bg-amber-900/30 hover:text-amber-700 dark:hover:text-amber-400 transition-colors">
    #{tag}
  </a>
) : (
  <span class="inline-block px-2 py-0.5 rounded-full text-xs bg-stone-100 dark:bg-stone-800 text-stone-500 dark:text-stone-400">
    #{tag}
  </span>
)}
